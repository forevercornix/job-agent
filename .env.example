# Nukopijuokite šį failą į .env ir įrašykite savo tikrus duomenis.
# .env failas NĖRA commit'inamas į git (žr. .gitignore) — jis lieka tik jūsų kompiuteryje.

ANTHROPIC_API_KEY=jusu-anthropic-api-raktas-cia

# Raktažodžiai atskirti kableliu
SEARCH_KEYWORDS=projektu vadovas,IT projektu vadovas,product owner,digital transformation

# CV / profilio santrauka (galima kelių eilučių tekstas kabutėse)
CANDIDATE_PROFILE="Juliana Vorono-Baranovska - IT projektų vadovė / Product Owner. 10+ metų patirtis: DVS/ERP/CRM diegimas, procesų skaitmenizacija, Agile/Scrum/PRINCE2, SQL, BPMN, IT valdymas. Ieško IT projektų vadovo arba Product Owner pozicijų Vilniuje/nuotoliniu būdu."

MIN_MATCH_SCORE=7
MAX_RESULTS_PER_SEARCH=20

# Kiek šaltinių naršyti vienu metu (lygiagrečiai). Konservatyvu = 3.
MAX_PARALLEL_SOURCES=3

# Mandagumo pauzė sekundėmis tarp užklausų TAM PAČIAM šaltiniui (ne tarp
# skirtingų šaltinių - jie naršomi lygiagrečiai, žr. docs/architecture.md)
COURTESY_PAUSE_SECONDS=2

# KAINOS APSAUGA: maksimalus naujų skelbimų skaičius, siunčiamas Claude API
# vertinimui per VIENĄ paleidimą (žr. README "Cost Control")
MAX_JOBS_PER_RUN=50
